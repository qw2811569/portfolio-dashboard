# Server-side env vars for Vercel functions.
# Do not put real secrets in this file.

# FinMind API token. Optional for local UI-only work, but required for higher
# upstream rate limits, structured cron pulls, and server-side FinMind routes.
FINMIND_TOKEN=

# Vercel Blob private store token used by brain / research / tracked-stocks /
# portfolio-snapshots / valuation / target-prices.
BLOB_READ_WRITE_TOKEN=

# Public app origin for absolute URLs and browser-facing signed private Blob reads.
APP_ORIGIN=

# Internal API origin for VM cron/worker self-calls; can differ from APP_ORIGIN.
INTERNAL_API_ORIGIN=

# App-level HMAC secret for signed private Blob reads. Blob tokens remain as
# legacy fallback during Phase 1 only.
BLOB_SIGNING_SECRET=

# Public Blob token reserved for telemetry only.
PUB_BLOB_TELEMETRY_TOKEN=

# Temporary legacy public Blob token kept during migration for residual public
# readers/writers that have not yet moved off the old store.
PUB_BLOB_READ_WRITE_TOKEN=

# Google Cloud Storage Phase 1 adapter envs (`ops.last_success_*` only for now).
GCS_PROJECT=
GCS_BUCKET_PUBLIC=
GCS_BUCKET_PRIVATE=
GCS_BUCKET_ARCHIVE=
STORAGE_PRIMARY_OPS_LAST_SUCCESS_PUBLIC=vercel
STORAGE_PRIMARY_OPS_LAST_SUCCESS_PRIVATE=vercel
STORAGE_SHADOW_READ_OPS_LAST_SUCCESS=false
STORAGE_SHADOW_WRITE_OPS_LAST_SUCCESS=false
STORAGE_PRIMARY_PORTFOLIO_TRACKED_STOCKS=vercel
STORAGE_SHADOW_READ_PORTFOLIO_TRACKED_STOCKS=false
STORAGE_SHADOW_WRITE_PORTFOLIO_TRACKED_STOCKS=false
# Remaining Class 1 singleton keyspaces (default Vercel primary + shadow off).
STORAGE_PRIMARY_VALUATION=vercel
STORAGE_SHADOW_READ_VALUATION=false
STORAGE_SHADOW_WRITE_VALUATION=false
STORAGE_PRIMARY_TARGET_PRICES=vercel
STORAGE_SHADOW_READ_TARGET_PRICES=false
STORAGE_SHADOW_WRITE_TARGET_PRICES=false
STORAGE_PRIMARY_DAILY_EVENTS=vercel
STORAGE_SHADOW_READ_DAILY_EVENTS=false
STORAGE_SHADOW_WRITE_DAILY_EVENTS=false
STORAGE_PRIMARY_NEWS_FEED=vercel
STORAGE_SHADOW_READ_NEWS_FEED=false
STORAGE_SHADOW_WRITE_NEWS_FEED=false
STORAGE_PRIMARY_ANALYST_REPORTS=vercel
STORAGE_SHADOW_READ_ANALYST_REPORTS=false
STORAGE_SHADOW_WRITE_ANALYST_REPORTS=false
STORAGE_PRIMARY_MORNING_NOTE=vercel
STORAGE_SHADOW_READ_MORNING_NOTE=false
STORAGE_SHADOW_WRITE_MORNING_NOTE=false
STORAGE_PRIMARY_BENCHMARK_SNAPSHOTS=vercel
STORAGE_SHADOW_READ_BENCHMARK_SNAPSHOTS=false
STORAGE_SHADOW_WRITE_BENCHMARK_SNAPSHOTS=false
STORAGE_PRIMARY_SNAPSHOT_RESEARCH=vercel
STORAGE_SHADOW_READ_SNAPSHOT_RESEARCH=false
STORAGE_SHADOW_WRITE_SNAPSHOT_RESEARCH=false
# Deprecated one-round fallback:
# STORAGE_PRIMARY_OPS_LAST_SUCCESS=vercel-only

# Shared cron bearer secret for Vercel cron-style endpoints and manual ops
# triggers. Keep the same value across the Vercel project + local dev when
# exercising protected cron routes.
CRON_SECRET=

# Primary AI provider key for `/api/analyze`, `/api/research`, `/api/parse`,
# and any Anthropic-backed server-side calls.
ANTHROPIC_API_KEY=

# Secondary AI provider key for Gemini grounding / fallback routes and local
# Gemini launch scripts.
GEMINI_API_KEY=

# VM Agent Bridge base URL
BRIDGE_BASE_URL=https://35.236.155.62.sslip.io

# Token used by Vercel serverless functions when calling VM Agent Bridge write endpoints.
# Keep the same env name in Vercel for both targets:
# - production BRIDGE_AUTH_TOKEN = prod token
# - preview BRIDGE_AUTH_TOKEN = preview token
BRIDGE_AUTH_TOKEN=

# Internal VM worker token used by Vercel `api/analyst-reports.js` when calling
# `POST /internal/analyst-reports`. On Vercel this can reuse BRIDGE_AUTH_TOKEN,
# but keep a separate env name so the route contract is explicit.
BRIDGE_INTERNAL_TOKEN=

# VM-only env for the standalone bridge process.
# Accepts preview writes without sharing the prod token.
BRIDGE_AUTH_TOKEN_PREVIEW=

# VM-only status write token used by `scripts/ai-status.sh`,
# `scripts/sync-todos-to-bridge.sh`, and similar bridge-side status updates.
VM_STATUS_TOKEN=

# Dashboard web UI PIN - 4-digit minimum · 建議每季輪換
# 用戶 iPhone 開 https://<agent-bridge-url>/ 要輸入此 PIN 才能送訊息
# 實值存 .env 本地 + VM /home/chenkuichen/.env
BRIDGE_DASHBOARD_PIN=
