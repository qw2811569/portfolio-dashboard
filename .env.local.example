# Agent Bridge — Local Environment
# Copy this file to .env.local on your Mac and set the VM URL.

# Push Mac ai-status.sh updates to VM Dashboard
# Uncomment and set your VM IP:
# VM_STATUS_URL=http://35.236.155.62:9527/api/local-status

# If VM has BRIDGE_AUTH_TOKEN set, Mac needs this to authenticate POSTs:
# VM_STATUS_TOKEN=your-bearer-token-here
