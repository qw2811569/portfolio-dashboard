# ============================================================
# .env 檔案分工（這個專案有 4 個，別搞混）
# ============================================================
#
# | 檔案                              | 用途                              | 誰讀 |
# |-----------------------------------|-----------------------------------|------|
# | .env                              | **Vercel 生產環境**（自動 inject） | Vercel / git tracked (no secrets) |
# | .env.local                        | **Mac 本地開發** + Vercel 覆寫    | bunx vercel dev / scripts |
# | .env.local.example (THIS FILE)    | **範本 — 複製成 .env.local 用**    | 人類看 |
# | .vercel/.env.preview.local        | Vercel preview branch override    | vercel CLI 自動管理 |
#
# 規則：
# 1. 不要 commit .env / .env.local（已在 .gitignore）
# 2. 改了這個範本 → 通知團隊同步各自的 .env.local
# 3. Vercel 上的 env var 從 Project Settings → Environment Variables 設定
#
# ============================================================

# ── Agent Bridge (Mac → VM Dashboard) ──
# Push Mac ai-status.sh updates to VM Agent Bridge
# VM_STATUS_URL=http://35.236.155.62:9527/api/local-status

# If VM has BRIDGE_AUTH_TOKEN set, Mac needs this to authenticate POSTs:
# VM_STATUS_TOKEN=your-bearer-token-here

# ── FinMind API（台股資料）──
# 付費帳號限額 1600 req/hr（不是文件寫的 600）
# FINMIND_TOKEN=your-finmind-jwt-here

# ── Anthropic Claude（收盤分析 / 深度研究）──
# ANTHROPIC_API_KEY=sk-ant-...

# ── Vercel Blob（private store for core app data）──
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_private_...

# ── Public app origin（browser-facing absolute URLs / signed Blob read links）──
# APP_ORIGIN=http://localhost:3002

# ── Internal API origin（VM cron / worker self-calls）──
# INTERNAL_API_ORIGIN=http://127.0.0.1:3002

# ── Signed Blob HMAC secret（Phase 1 新增；Blob token 只剩 legacy fallback）──
# BLOB_SIGNING_SECRET=replace-with-a-random-32-byte-secret

# ── Vercel Blob（public telemetry only）──
# PUB_BLOB_TELEMETRY_TOKEN=vercel_blob_rw_public_...

# ── Vercel Blob（legacy public token · temporary during migration）──
# PUB_BLOB_READ_WRITE_TOKEN=vercel_blob_rw_public_...

# ── GCS（Phase 1 last-success adapter）──
# GCS_PROJECT=jcv-dev-2026
# GCS_BUCKET_PUBLIC=jcv-dev-public
# GCS_BUCKET_PRIVATE=jcv-dev-private
# GCS_BUCKET_ARCHIVE=jcv-dev-archive
# STORAGE_PRIMARY_OPS_LAST_SUCCESS_PUBLIC=vercel
# STORAGE_PRIMARY_OPS_LAST_SUCCESS_PRIVATE=vercel
# STORAGE_SHADOW_READ_OPS_LAST_SUCCESS=false
# STORAGE_SHADOW_WRITE_OPS_LAST_SUCCESS=false
# STORAGE_PRIMARY_PORTFOLIO_TRACKED_STOCKS=vercel
# STORAGE_SHADOW_READ_PORTFOLIO_TRACKED_STOCKS=false
# STORAGE_SHADOW_WRITE_PORTFOLIO_TRACKED_STOCKS=false
# Remaining Class 1 singleton keyspaces (default Vercel primary + shadow off):
# STORAGE_PRIMARY_VALUATION=vercel
# STORAGE_SHADOW_READ_VALUATION=false
# STORAGE_SHADOW_WRITE_VALUATION=false
# STORAGE_PRIMARY_TARGET_PRICES=vercel
# STORAGE_SHADOW_READ_TARGET_PRICES=false
# STORAGE_SHADOW_WRITE_TARGET_PRICES=false
# STORAGE_PRIMARY_DAILY_EVENTS=vercel
# STORAGE_SHADOW_READ_DAILY_EVENTS=false
# STORAGE_SHADOW_WRITE_DAILY_EVENTS=false
# STORAGE_PRIMARY_NEWS_FEED=vercel
# STORAGE_SHADOW_READ_NEWS_FEED=false
# STORAGE_SHADOW_WRITE_NEWS_FEED=false
# STORAGE_PRIMARY_ANALYST_REPORTS=vercel
# STORAGE_SHADOW_READ_ANALYST_REPORTS=false
# STORAGE_SHADOW_WRITE_ANALYST_REPORTS=false
# STORAGE_PRIMARY_MORNING_NOTE=vercel
# STORAGE_SHADOW_READ_MORNING_NOTE=false
# STORAGE_SHADOW_WRITE_MORNING_NOTE=false
# STORAGE_PRIMARY_BENCHMARK_SNAPSHOTS=vercel
# STORAGE_SHADOW_READ_BENCHMARK_SNAPSHOTS=false
# STORAGE_SHADOW_WRITE_BENCHMARK_SNAPSHOTS=false
# STORAGE_PRIMARY_SNAPSHOT_RESEARCH=vercel
# STORAGE_SHADOW_READ_SNAPSHOT_RESEARCH=false
# STORAGE_SHADOW_WRITE_SNAPSHOT_RESEARCH=false
# STORAGE_PRIMARY_SNAPSHOT_BRAIN=vercel
# STORAGE_SHADOW_READ_SNAPSHOT_BRAIN=false
# STORAGE_SHADOW_WRITE_SNAPSHOT_BRAIN=false
# STORAGE_PRIMARY_SNAPSHOT_PORTFOLIO_STATE=vercel
# STORAGE_SHADOW_READ_SNAPSHOT_PORTFOLIO_STATE=false
# STORAGE_SHADOW_WRITE_SNAPSHOT_PORTFOLIO_STATE=false
# Class 3 append logs use monthly JSONL rotation plus RMW CAS retry:
# STORAGE_PRIMARY_MORNING_NOTE_LOG=vercel
# STORAGE_SHADOW_READ_MORNING_NOTE_LOG=false
# STORAGE_SHADOW_WRITE_MORNING_NOTE_LOG=false
# STORAGE_PRIMARY_DAILY_SNAPSHOT_LOG=vercel
# STORAGE_SHADOW_READ_DAILY_SNAPSHOT_LOG=false
# STORAGE_SHADOW_WRITE_DAILY_SNAPSHOT_LOG=false
# STORAGE_PRIMARY_RESTORE_REHEARSAL_LOG=vercel
# STORAGE_SHADOW_READ_RESTORE_REHEARSAL_LOG=false
# STORAGE_SHADOW_WRITE_RESTORE_REHEARSAL_LOG=false
# Deprecated one-round fallback:
# STORAGE_PRIMARY_OPS_LAST_SUCCESS=vercel-only

# ── Cron 授權 ──
# CRON_SECRET=your-cron-secret
