#!/bin/sh
set -e

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  . "$NVM_DIR/nvm.sh"
  nvm use --silent >/dev/null 2>&1 || true
fi

npm run theme:check || {
  echo "❌ theme drift. Run: npm run theme:sync"
  exit 1
}

npx lint-staged

npm run theme:check || {
  echo "❌ theme drift after staged formatting. Run: npm run theme:sync"
  exit 1
}

npm run check:facade-alias -- --staged
