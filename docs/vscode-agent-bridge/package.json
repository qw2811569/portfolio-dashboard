{
  "name": "agent-bridge",
  "displayName": "Agent Bridge — Mobile AI Control",
  "description": "從手機監控和操控 VS Code 裡的 AI coding agents（Claude, Codex, Qwen, Gemini）",
  "version": "0.1.0",
  "publisher": "kuei",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentBridge.start",
        "title": "Agent Bridge: Start Server"
      },
      {
        "command": "agentBridge.stop",
        "title": "Agent Bridge: Stop Server"
      },
      {
        "command": "agentBridge.showQR",
        "title": "Agent Bridge: Show Connection QR Code"
      }
    ],
    "configuration": {
      "title": "Agent Bridge",
      "properties": {
        "agentBridge.port": {
          "type": "number",
          "default": 9527,
          "description": "Dashboard server port"
        },
        "agentBridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Auto-start server when VS Code opens"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.93.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
