      "lastRevenueDate": "2026-02-10",
      "revenueFrequency": "monthly"
    }
  },
  "expect": {
    "bucket": "stale",
    "mustMentionIssues": ["月營收"],
    "suggestedAction": "等待或查詢最新月營收公告"
  }
