{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "maxNodeModuleJsDepth": 0,
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "tests/**/*.js",
    "tests/**/*.jsx",
    "api/**/*.js",
    "scripts/**/*.mjs",
    "scripts/**/*.cjs"
  ],
  "exclude": [".archive", ".tmp", "dist", "docs", "node_modules"]
}
