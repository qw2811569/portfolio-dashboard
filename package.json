{
  "name": "portfolio-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3002 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "theme:sync": "node scripts/sync-theme-from-canonical.mjs",
    "theme:check": "node scripts/sync-theme-from-canonical.mjs --check",
    "check:facade-alias": "node scripts/check-facade-alias.mjs",
    "check:fast-refresh": "node scripts/check-fast-refresh-boundaries.mjs",
    "check:runtime-entry": "node scripts/check-runtime-entry.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:js-critical": "tsc --noEmit -p tsconfig.checkjs.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "healthcheck": "bash scripts/healthcheck.sh",
    "smoke:ui": "node scripts/ui-smoke.cjs",
    "backfill:target-prices": "node scripts/backfill-target-prices.mjs",
    "morning-note:worker": "node agent-bridge-standalone/workers/morning-note-worker.mjs",
    "tw-events:worker": "node agent-bridge-standalone/workers/tw-events-worker.mjs",
    "snapshot:worker": "node agent-bridge-standalone/workers/snapshot-worker.mjs",
    "audit:data-coverage": "node scripts/audit-data-coverage.mjs",
    "verify:local": "npm run check:facade-alias && npm run theme:check && npm run check:runtime-entry && npm run check:fast-refresh && npm run lint && npm run typecheck && npm run typecheck:js-critical && npm run test:run && npm run audit:data-coverage && npm run build && npm run healthcheck && npm run smoke:ui",
    "checkpoint": "bash scripts/create-checkpoint.sh",
    "checkpoint:git": "bash scripts/git-checkpoint.sh",
    "prepare": "husky",
    "gemini:research": "node api/gemini-research.js run"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@tanstack/react-query": "^5.95.2",
    "@vercel/blob": "^2.3.1",
    "express": "^4.22.1",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
