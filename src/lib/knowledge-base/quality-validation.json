{
  "name": "知識庫品質驗證框架",
  "version": "1.0.0",
  "description": "定義知識庫條目品質的五維評分標準和 deprecation flow",
  "qualityCriteria": {
    "actionability": {
      "weight": 0.30,
      "description": "是否有具體可執行動作",
      "scoring": {
        "100": "有明確買賣訊號和量化門檻",
        "70": "有方向但無具體門檻",
        "40": "只有模糊建議（觀察、注意、留意）",
        "0": "無行動建議"
      }
    },
    "specificity": {
      "weight": 0.25,
      "description": "是否有量化條件或具體門檻",
      "scoring": {
        "100": "有 3 個以上量化指標",
        "80": "有 2 個量化指標",
        "60": "有 1 個量化指標",
        "30": "無量化指標"
      }
    },
    "verifiability": {
      "weight": 0.20,
      "description": "是否可驗證/可證偽",
      "scoring": {
        "100": "有明確驗證條件和時間框架",
        "70": "有驗證條件但無時間框架",
        "40": "難以驗證"
      }
    },
    "reusability": {
      "weight": 0.15,
      "description": "是否可重複使用（非單一事件）",
      "scoring": {
        "100": "通用規則，適用於所有標的和時點",
        "70": "適用於特定情境或產業",
        "30": "單一事件或特定時點"
      }
    },
    "sourceQuality": {
      "weight": 0.10,
      "description": "來源是否可靠",
      "scoring": {
        "100": "有明確來源且為權威（財報分析、技術分析等）",
        "70": "有來源但不明確",
        "40": "無來源"
      }
    }
  },
  "scoringSystem": {
    "totalScore": "actionability*0.30 + specificity*0.25 + verifiability*0.20 + reusability*0.15 + sourceQuality*0.10",
    "thresholds": {
      "highQuality": 80,
      "acceptable": 60,
      "lowQuality": 50,
      "critical": 40
    }
  },
  "validationProcess": {
    "steps": [
      {
        "step": 1,
        "action": "自動評分",
        "frequency": "每次 KB 修改後",
        "owner": "validate-knowledge.js script"
      },
      {
        "step": 2,
        "action": "低分條目標記",
        "condition": "總分 < 60 或 critical 維度 < 40",
        "owner": "Qwen"
      },
      {
        "step": 3,
        "action": "人工審查並改寫",
        "frequency": "每季定期執行",
        "owner": "Qwen"
      },
      {
        "step": 4,
        "action": "降 confidence 或移除",
        "condition": "改寫後仍 < 50 分",
        "owner": "Codex"
      }
    ]
  },
  "redFlags": [
    "action 欄位包含模糊詞（觀察、注意、留意、適時、酌情）",
    "無量化指標（數字、百分比、倍數）",
    "無時間框架（日、週、月、季）",
    "無來源或來源不明",
    "單一事件不可重複使用"
  ],
  "greenFlags": [
    "action 包含明確買賣訊號（買進、賣出、減碼、加碼、停損）",
    "有 2 個以上量化指標",
    "有時間框架",
    "來源明確且權威",
    "通用規則可重複使用"
  ],
  "deprecationFlow": {
    "conditions": [
      "總分 < 40（critical）",
      "misleadingCount > helpfulCount 且 misleadingCount >= 2",
      "totalUsage == 0 且 confidence < 0.50"
    ],
    "actions": [
      "標記 status = 'deprecated'",
      "confidence 降至 0.40 以下",
      "從 prompt 注入排除"
    ]
  },
  "autoAdjustRules": {
    "description": "Confidence 自動調整規則（需 feedback 數據支持）",
    "rules": [
      {
        "condition": "totalUsage == 0",
        "action": "confidence = max(0.50, confidence - 0.05)",
        "reason": "從未被用過，可能不相關"
      },
      {
        "condition": "misleadingCount >= 2 && misleadingCount > helpfulCount",
        "action": "confidence = max(0.40, confidence - 0.10); status = 'pending-review'",
        "reason": "被標記為誤導多於有幫助"
      },
      {
        "condition": "helpfulCount >= 3 && helpfulCount > misleadingCount * 2",
        "action": "confidence = min(0.95, confidence + 0.05)",
        "reason": "持續有幫助"
      }
    ],
    "executionFrequency": "每季或每 50 筆新 feedback"
  }
}
