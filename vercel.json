{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- src/ api/ index.html vite.config.js vercel.json package.json",
  "crons": [
    {
      "path": "/api/cron/collect-daily-events",
      "schedule": "0 8 * * 1-5"
    }
  ],
  "rewrites": [
    { "source": "/api/twse", "destination": "/api/twse" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "functions": {
    "api/analyze.js": {
      "maxDuration": 60
    },
    "api/research.js": {
      "maxDuration": 300
    },
    "api/event-calendar.js": {
      "maxDuration": 60
    },
    "api/parse.js": {
      "maxDuration": 30
    },
    "api/*.js": {
      "maxDuration": 10
    }
  }
}
