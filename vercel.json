{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "ignoreCommand": "if [ -z \"$VERCEL_GIT_PREVIOUS_SHA\" ]; then exit 1; fi && git fetch --depth=1 origin \"$VERCEL_GIT_PREVIOUS_SHA\" 2>/dev/null && git diff --quiet \"$VERCEL_GIT_PREVIOUS_SHA\" HEAD -- src/ api/ index.html vite.config.js vercel.json package.json",
  "crons": [
    {
      "path": "/api/cron/collect-daily-events",
      "schedule": "0 8 * * 1-5"
    },
    {
      "path": "/api/cron/collect-target-prices",
      "schedule": "30 9 * * 1-5"
    },
    {
      "path": "/api/cron/collect-news",
      "schedule": "0 10 * * 1-5"
    }
  ],
  "rewrites": [
    { "source": "/api/twse", "destination": "/api/twse" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "functions": {
    "api/analyze.js": {
      "maxDuration": 60
    },
    "api/research.js": {
      "maxDuration": 300
    },
    "api/event-calendar.js": {
      "maxDuration": 60
    },
    "api/parse.js": {
      "maxDuration": 30
    },
    "api/cron/collect-news.js": {
      "maxDuration": 60
    },
    "api/cron/collect-target-prices.js": {
      "maxDuration": 60
    },
    "api/*.js": {
      "maxDuration": 10
    }
  }
}
