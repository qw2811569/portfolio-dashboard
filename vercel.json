{
  "framework": "vite",
  "crons": [
    {
      "path": "/api/cron/collect-daily-events",
      "schedule": "0 8 * * 1-5"
    }
  ],
  "rewrites": [
    { "source": "/api/twse", "destination": "/api/twse" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "functions": {
    "api/analyze.js": {
      "maxDuration": 60
    },
    "api/research.js": {
      "maxDuration": 60
    },
    "api/parse.js": {
      "maxDuration": 30
    },
    "api/*.js": {
      "maxDuration": 10
    }
  }
}
