{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "ignoreCommand": "bash scripts/vercel-ignore.sh",
  "cronsRetirementNote": "will be retired Phase 5; retained during Phase 2 systemd rollback window",
  "crons": [
    {
      "path": "/api/cron/compute-valuations",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/collect-daily-events",
      "schedule": "0 8 * * 1-5"
    },
    {
      "path": "/api/cron/collect-target-prices",
      "schedule": "30 9 * * 1-5"
    },
    {
      "path": "/api/cron/collect-news",
      "schedule": "0 10 * * 1-5"
    }
  ],
  "rewrites": [
    { "source": "/api/twse", "destination": "/api/twse" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' blob:; style-src 'self' 'unsafe-inline' https:; font-src 'self' https: data:; img-src 'self' https: data: blob:; connect-src 'self' https://*.vercel-storage.com https://api.finmindtrade.com https://newsapi.org https://35.236.155.62.sslip.io"
        },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "functions": {
    "api/analyze.js": {
      "maxDuration": 60
    },
    "api/research.js": {
      "maxDuration": 300
    },
    "api/event-calendar.js": {
      "maxDuration": 60
    },
    "api/parse.js": {
      "maxDuration": 30
    },
    "api/cron/collect-news.js": {
      "maxDuration": 60
    },
    "api/cron/compute-valuations.js": {
      "maxDuration": 300
    },
    "api/cron/collect-target-prices.js": {
      "maxDuration": 60
    },
    "api/*.js": {
      "maxDuration": 10
    }
  }
}
